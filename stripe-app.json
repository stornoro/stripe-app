{
  "connect_permissions": null,
  "distribution_type": "private",
  "icon": "./icon.png",
  "id": "com.storno.stripe-app",
  "name": "Storno",
  "permissions": [
    {
      "permission": "customer_read",
      "purpose": "Match Stripe customers with Storno.ro clients by tax ID, email, or name"
    },
    {
      "permission": "charge_read",
      "purpose": "Resolve which Stripe invoice is linked to a charge when creating credit notes"
    },
    {
      "permission": "payment_intent_read",
      "purpose": "Display payment status and link payments to e-Factura invoices"
    },
    {
      "permission": "invoice_read",
      "purpose": "Read Stripe invoices to create and link e-Factura documents"
    },
    {
      "permission": "subscription_read",
      "purpose": "List subscription billing cycles and their linked e-Factura invoices"
    },
    {
      "permission": "secret_write",
      "purpose": "Store authentication tokens securely per Stripe user"
    }
  ],
  "ui_extension": {
    "content_security_policy": {
      "connect-src": [
        "https://api.storno.ro/api/"
      ],
      "image-src": null,
      "purpose": "Communicate with Storno.ro backend API"
    },
    "views": [
      {
        "component": "InvoiceListView",
        "viewport": "stripe.dashboard.home.overview"
      },
      {
        "component": "ClientDetailView",
        "viewport": "stripe.dashboard.customer.detail"
      },
      {
        "component": "InvoiceDetailView",
        "viewport": "stripe.dashboard.payment.detail"
      },
      {
        "component": "StripeInvoiceDetailView",
        "viewport": "stripe.dashboard.invoice.detail"
      },
      {
        "component": "SubscriptionDetailView",
        "viewport": "stripe.dashboard.subscription.detail"
      },
      {
        "component": "SettingsView",
        "viewport": "settings"
      }
    ]
  },
  "version": "1.0.1"
}